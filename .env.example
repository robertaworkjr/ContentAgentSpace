# Environment Variables — ContentAgent.Space
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ──────────────────────────────────────────────
# SUPABASE (Frontend)
# Supabase Dashboard → Settings → API
# ──────────────────────────────────────────────
VITE_SUPABASE_URL=https://jpfmfvivpywoxywbgxuc.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ──────────────────────────────────────────────
# STRIPE (Frontend — publishable key only)
# Stripe Dashboard → Developers → API Keys
# ──────────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key-here

# ──────────────────────────────────────────────
# ANTHROPIC — AI Agent (/agent endpoint)
# platform.anthropic.com → API Keys
# ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
AGENT_MODEL=claude-sonnet-4-20250514
AGENT_MAX_TOKENS=600

# ── Business Identity (customise per client demo) ──────────────────────────────
BUSINESS_NAME=ContentAgent.Space
AGENT_NAME=Alex
BUSINESS_REGION=Liverpool, UK
BUSINESS_BOOKING_URL=https://contentagent.space/get-started

# ── Business Context (paste website / FAQ content here, max ~3000 chars) ───────
BUSINESS_CONTEXT=ContentAgent.Space creates high-quality short-form video content for TikTok, Instagram Reels, and YouTube Shorts. Services include video scripting, editing, and AI-optimised content strategy. Contact us to book a discovery call.

# ── CORS — set to your exact domain in production ──────────────────────────────
# e.g. https://contentagent.space
ALLOWED_ORIGIN=https://contentagent.space
