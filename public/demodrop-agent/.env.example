# contentagent.space — Demo Agent Environment Variables
# Copy this to .env for local dev (netlify dev reads it automatically)
# Set these same vars in your Netlify dashboard → Site Settings → Environment Variables

# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
AGENT_MODEL=claude-sonnet-4-20250514
AGENT_MAX_TOKENS=600

# ── Business Identity ──────────────────────────────────────────────────────────
BUSINESS_NAME=Your Business Name
AGENT_NAME=Alex

# ── Business Context (paste scraped website content / FAQs / services here) ───
# Keep this under ~3000 characters for best results.
# Tip: scrape with Turbomock or manually paste from the About, Services, FAQ pages.
BUSINESS_CONTEXT=We are a [type of business] based in [location]. We offer [service 1], [service 2], and [service 3]. Our team has [X] years of experience. Frequently asked questions: [paste FAQs here].

# ── Location & Booking ─────────────────────────────────────────────────────────
BUSINESS_REGION=Liverpool, UK
BUSINESS_BOOKING_URL=https://calendly.com/yourbusiness

# ── CORS ───────────────────────────────────────────────────────────────────────
# Set this to your exact domain in production, e.g. https://contentagent.space
ALLOWED_ORIGIN=*
